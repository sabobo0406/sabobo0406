# === 必須設定 ===
# Twitter API Bearer Token
# 取得方法: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here

# === オプション設定 ===
# 監視対象のXアカウント名（@なし）
TARGET_USERNAME=ajog_thegray

# PDFダウンロード先ディレクトリ
DOWNLOAD_DIR=papers

# 定期監視の間隔（分）
CHECK_INTERVAL_MINUTES=60

# 状態保存ファイル
STATE_FILE=downloader_state.json

# Unpaywall API用メールアドレス（OAのPDFを取得するために推奨）
# 登録不要・無料で使えます
UNPAYWALL_EMAIL=your_email@example.com
