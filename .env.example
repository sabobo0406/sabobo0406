# === 基本設定（API不要） ===
# 監視対象のXアカウント名（@なし）
TARGET_USERNAME=ajog_thegray

# PDFダウンロード先ディレクトリ
DOWNLOAD_DIR=papers

# 定期監視の間隔（分）
CHECK_INTERVAL_MINUTES=60

# ページスクロール回数（多いほど多くのツイートを取得）
SCROLL_COUNT=5

# 状態保存ファイル
STATE_FILE=downloader_state.json

# === オプション ===
# Unpaywall API用メールアドレス（OA論文PDFを取得するために推奨・登録不要）
UNPAYWALL_EMAIL=your_email@example.com
