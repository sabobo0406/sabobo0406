# ─────────────────────────────────────────────────────────────
# kuru-kuru 環境変数サンプル
# このファイルを .env.local にコピーして、使う機能のキーだけ埋めてください。
# キーが無い項目は自動でモックデータにフォールバックします（画面はすぐ動きます）。
# ─────────────────────────────────────────────────────────────

# ── 記事下書き生成（Claude / Anthropic）──────────────────────
# /transcribe の「記事下書き」で使用。https://console.anthropic.com で取得。
ANTHROPIC_API_KEY=

# ── 文字起こし（OpenAI Whisper）─────────────────────────────
# /transcribe の音声・動画→テキスト変換で使用。https://platform.openai.com で取得。
OPENAI_API_KEY=
# 文字起こしモデル（既定: whisper-1。gpt-4o-transcribe も可）
TRANSCRIBE_MODEL=whisper-1

# ── Instagram（Instagram Graph API / Meta）──────────────────
# 競合巡回・ダッシュボードのフォロワー数で使用。
# Meta for Developers でビジネス連携済みの長期トークンが必要。
INSTAGRAM_ACCESS_TOKEN=
# 自分のビジネスアカウントID（ダッシュボードのフォロワー数集計用）
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# 巡回したい競合の Instagram ユーザー名（カンマ区切り。例: nike,adidas）
COMPETITOR_INSTAGRAM_USERNAMES=

# ── X / Twitter（X API v2）──────────────────────────────────
# 競合巡回・ダッシュボードで使用。Bearer トークン。
X_BEARER_TOKEN=
# 巡回したい競合の X ユーザー名（カンマ区切り。@ は不要）
COMPETITOR_X_USERNAMES=

# ── 売上（Stripe）───────────────────────────────────────────
# ダッシュボードの売上集計で使用。sk_live_ または sk_test_。
STRIPE_SECRET_KEY=

# ── 巡回レポートの抽出しきい値 ──────────────────────────────
# 前日比でこの割合(%)以上 伸びた投稿だけをレポートに含める（既定: 20）
GROWTH_THRESHOLD_PERCENT=20
